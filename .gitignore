# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# mcp config (contains tokens)
.mcp.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# scratch files and debug artifacts
/scratch/
/logs_llm/
.data/

# Cursor IDE local worktree paths
.cursor/worktrees.json

# worktrees
.worktrees/
.superpowers/

# playwright MCP artifacts
.playwright-mcp/

# local codebase index cache (regenerated by tooling; do not commit)
.codebase-index-cache.json

# local Kandy folder → vertical map (optional; see scripts/kandy-folder-map.example.json)
scripts/kandy-folder-map.json

# supabase CLI local cache
supabase/.temp/

# screenshots
*.png
# Nano Banana template previews (catalog: lib/ad-creatives/nano-banana/catalog-data.ts)
!public/nano-banana-previews/*.png
# Favicons
!public/favicon.png
!public/favicon-ac.png
!public/avatar-nativz.png
!public/avatar-anderson.png
!app/apple-icon.png
# Agency logo PNGs — dark-on-light variants used by branded PDFs
!public/nativz-logo.png
!public/nativz-logo-on-light.png
!public/anderson-logo.png
!public/anderson-logo-on-light.png
# Self-hosted proposal pages: agency logos, sample brand thumbnails, etc.
!public/proposal-assets/**/*.png
!public/proposal-assets/**/*.jpg
!app/icon.png
vectors.db
vectors.db-shm
vectors.db-wal
/test-results/

# Local absolute paths to Goldback product shots (regenerate: find … > scripts/.goldback-idaho-image-pool.txt)
scripts/.goldback-idaho-image-pool.txt
tmp/

# Accessibility / DOM snapshots dumped by Playwright MCP during local debugging.
# These are working artifacts, not source — keep them out of commits.
/*-snapshot.md

# Claude Code scheduled-tasks plugin runtime lockfile.
.claude/scheduled_tasks.lock
