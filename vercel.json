{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "build": {
    "env": {
      "VERCEL_FORCE_NO_BUILD_CACHE": "1"
    }
  },
  "crons": [
    {
      "path": "/api/cron/shoot-planner",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sync-reporting",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/sync-reporting",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/publish-posts",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/check-velocity",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/sync-affiliates",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/fyxer-import",
      "schedule": "15,45 * * * *"
    },
    {
      "path": "/api/cron/data-retention",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-knowledge-graph",
      "schedule": "15 */6 * * *"
    },
    {
      "path": "/api/cron/weekly-affiliate-report",
      "schedule": "*/15 * * * *"
    }
  ]
}
