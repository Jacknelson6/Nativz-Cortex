+// Best-effort fetch of the Cortex proposal id from the folder's client.json.
+// Lets us pass it as `client_reference_id` on the Stripe redirect so Cortex
+// can link the paid session back to the proposal record.
+async function fetchCortexProposalId(request: Request, slug: string): Promise<string | null> {
+  try {
+    const origin = new URL(request.url).origin;
+    const res = await fetch(`${origin}/${encodeURIComponent(slug)}/client.json`, { cf: { cacheTtl: 60 } });
+    if (!res.ok) return null;
+    const doc = await res.json() as { source?: { cortexProposalId?: string } };
+    return doc.source?.cortexProposalId || null;
+  } catch {
+    return null;
+  }
+}
