+/// <reference types="@cloudflare/workers-types" />
+/**
+ * Fire an authenticated callback to Cortex after a sign/paid/viewed event.
+ *
+ * Cortex side: POST /api/webhooks/docs/[event]
+ * Auth: shared bearer token (DOCS_WEBHOOK_SECRET — same value in this CF
+ *       project's env and Cortex's Vercel env).
+ *
+ * Failure policy: we log + swallow. A CF sign flow must not hard-fail just
+ * because Cortex is down — the canonical record is already in this project's
+ * KV, and Cortex can reconcile later by reading `external_folder`.
+ */
+
+export interface CortexEnv {
+  CORTEX_WEBHOOK_URL?: string;      // e.g. https://cortex.andersoncollaborative.com
+  DOCS_WEBHOOK_SECRET?: string;
+}
+
+export async function postToCortex(
+  env: CortexEnv,
+  event: 'viewed' | 'signed' | 'paid',
+  body: Record<string, unknown>,
+): Promise<{ ok: boolean; status?: number; error?: string }> {
+  const base = env.CORTEX_WEBHOOK_URL?.replace(/\/+$/, '');
+  const secret = env.DOCS_WEBHOOK_SECRET;
+  if (!base || !secret) {
+    console.warn('[cortex-callback] CORTEX_WEBHOOK_URL or DOCS_WEBHOOK_SECRET not set — skipping.');
+    return { ok: false, error: 'not-configured' };
+  }
+  try {
+    const res = await fetch(`${base}/api/webhooks/docs/${event}`, {
+      method: 'POST',
+      headers: {
+        'Authorization': `Bearer ${secret}`,
+        'Content-Type': 'application/json',
+      },
+      body: JSON.stringify(body),
+    });
+    if (!res.ok) {
+      const text = await res.text().catch(() => '');
+      console.error(`[cortex-callback:${event}] ${res.status}: ${text}`);
+      return { ok: false, status: res.status, error: text };
+    }
+    return { ok: true, status: res.status };
+  } catch (e) {
+    console.error(`[cortex-callback:${event}] threw:`, e);
+    return { ok: false, error: e instanceof Error ? e.message : String(e) };
+  }
+}
