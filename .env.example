# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenRouter (AI model gateway)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Brave Search API (web search data gathering)
BRAVE_SEARCH_API_KEY=BSA...

# App
NEXT_PUBLIC_APP_URL=https://cortex.nativz.com

# TrustGraph context layer (optional — see docs/trustgraph-context-layer.md)
# CONTEXT_PLATFORM_MODE=off
# CONTEXT_PLATFORM_SCOPE=both
# TRUSTGRAPH_BASE_URL=http://localhost:8080
# TRUSTGRAPH_API_KEY=
# cortex (custom proxy) or native (TrustGraph flow services: embeddings + document/graph-embeddings)
# TRUSTGRAPH_API_STYLE=cortex
# TRUSTGRAPH_FLOW_ID=my-flow
# TRUSTGRAPH_USER=cortex
# TRUSTGRAPH_CLIENT_COLLECTION_PREFIX=cortex-client-
# TRUSTGRAPH_AGENCY_COLLECTION=default
# TRUSTGRAPH_CLIENT_SEARCH_PATH=/api/v1/cortex/client-search
# TRUSTGRAPH_AGENCY_SEARCH_PATH=/api/v1/cortex/agency-search
# TRUSTGRAPH_TIMEOUT_MS=12000
# TRUSTGRAPH_CIRCUIT_FAILURES=5
# TRUSTGRAPH_CIRCUIT_OPEN_MS=60000
# npm run trustgraph:smoke — optional TRUSTGRAPH_SMOKE_CLIENT_ID, TRUSTGRAPH_SMOKE_QUERY

# TrustGraph Workbench UI in Admin → Knowledge graph (embed iframe + tab). Gateway is often :8080; Workbench defaults to :8888 — see https://github.com/trustgraph-ai/trustgraph
# NEXT_PUBLIC_TRUSTGRAPH_WORKBENCH_URL=http://localhost:8888
