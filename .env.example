# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenRouter (AI model gateway)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free

# OpenAI image generation (monthly gift ads / ChatGPT Image pipeline)
# OPENAI_API_KEY=sk-proj-...
# CHATGPT_IMAGE_MODEL=gpt-image-1.5
# CHATGPT_IMAGE_QUALITY=medium
# AD_REFERENCE_DRIVE_FOLDER_URL=https://drive.google.com/drive/folders/1QNJjbvjWfQGy_DsEppJBAApAt7mp3Abk
# AD_REFERENCE_SYNC_LIMIT=300
# AD_MONTHLY_GIFT_MAX_CLIENTS_PER_CRON=2

# Brave Search API (web search data gathering)
BRAVE_SEARCH_API_KEY=BSA...

# App
NEXT_PUBLIC_APP_URL=https://cortex.nativz.com

# Prospect scorecard public share page — strategist email used for the lead CTA
PROSPECT_SCORECARD_LEAD_EMAIL=hello@nativz.io
# Salt used when hashing viewer IPs for prospect_share_link_views.
# PROSPECT_VIEW_IP_SALT=cortex-prospect-share

# Topic search admin alerts (cron /api/cron/topic-search-notify — requires CRON_SECRET)
# TOPIC_SEARCH_STUCK_PROCESSING_MINUTES=25
# TOPIC_SEARCH_STUCK_QUEUE_MINUTES=90

# Apify (TikTok search in topic pipeline — lib/tiktok/search.ts)
# APIFY_API_KEY=
# Default actor: apidojo/tiktok-scraper (~$0.30/1k results; keyword + dateRange + sortType + location). Legacy: clockworks~tiktok-scraper
# APIFY_TIKTOK_ACTOR_ID=apidojo/tiktok-scraper
# RELEVANCE | MOST_LIKED | DATE_POSTED (keyword search only)
# APIFY_TIKTOK_SORT_TYPE=RELEVANCE
# Optional ISO 3166-1 alpha-2 region filter (e.g. US, GB)
# APIFY_TIKTOK_LOCATION=
# Force input JSON shape if actor slug is ambiguous: apidojo | clockworks
# APIFY_TIKTOK_INPUT_MODE=

# Reddit (topic search — lib/reddit/client.ts + lib/reddit/apify-trudax.ts)
# Uses APIFY_API_KEY. Searches all of Reddit by keyword (no subreddit discovery).
# Default actor: trudax/reddit-scraper-lite. Sort defaults to "hot".
# APIFY_REDDIT_ACTOR_ID=trudax/reddit-scraper-lite
# hot | new | top | rising | relevance
# APIFY_REDDIT_SORT=hot

# Web SERP (topic search — lib/serp/client.ts)
# Default actor: scraperlink/google-search-results-serp-scraper. Uses APIFY_API_KEY.
# APIFY_GOOGLE_SERP_ACTOR_ID=scraperlink/google-search-results-serp-scraper

# Resend (transactional email — used by Revenue Hub kickoff reminders etc.)
# RESEND_API_KEY=re_...
# Resend Svix webhook secret(s) (SPY-10 stickiness telemetry). Set one or more.
# RESEND_WEBHOOK_SECRET=whsec_...
# RESEND_WEBHOOK_SECRET_NATIVZ=whsec_...
# RESEND_WEBHOOK_SECRET_ANDERSON=whsec_...
# From address for SPY-10 prospect digests (optional override).
# PROSPECT_DIGEST_FROM=Jack from Nativz <jack@nativz.io>

# Stripe (Revenue Hub — /admin/revenue). Live keys only; no test/livemode branching in code.
# Mirror to Vercel dashboard → Settings → Environment Variables (Production + Preview).
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_RESTRICTED_KEY=rk_live_...              # read-only — reserved for future
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_... # unused in MVP (no client-side Stripe.js yet)
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_ENDPOINT_ID=we_...               # metadata only

# Cron auth — used by /api/cron/* routes. Set in Vercel project settings.
# Generate with: openssl rand -hex 16
# CRON_SECRET=

# Viral Format Finder discovery (VFF-03)
# Per-brand daily ceiling on newly inserted videos. Cron short-circuits when hit.
VFF_DAILY_VIDEOS_PER_BRAND=50
# Apify actor ids used by VFF discovery scrapers.
VFF_APIFY_TIKTOK_ACTOR=clockworks/tiktok-scraper
VFF_APIFY_IG_ACTOR=apify/instagram-scraper
# YouTube Data API key (read-only) for shorts discovery + per-video metadata.
YOUTUBE_DATA_API_KEY=

# Prospect monitor (SPY-06) delta-rule thresholds. All optional; defaults
# baked into lib/prospects/delta-rules.ts. Tune per real-world signal/noise
# once we have a few weeks of alerts to grade.
# Follower-jump rule fires when curr/prev ratio crosses this percent AND
# absolute delta is at least PROSPECT_MONITOR_FOLLOWER_JUMP_ABS.
# PROSPECT_MONITOR_FOLLOWER_JUMP_PCT=10
# PROSPECT_MONITOR_FOLLOWER_JUMP_ABS=500
# Viral-post rule fires when latest top post's view count is at least N x
# the median of the prospect's last 10 posts.
# PROSPECT_MONITOR_VIRAL_MULT=5
# Best-effort high-severity push fan-out. Optional; replaced by SPY-10's
# proper notification helper once it lands. POST endpoint receiving JSON
# { title, body, prospect_id }.
# PUSH_NOTIFY_URL=


# CUP-02 SMM review notifications. SLACK_OPS_WEBHOOK_URL is the incoming-
# webhook URL for the ops Slack channel that gets pinged when an editor
# hands a drop off to the SMM. SLACK_OPS_WEBHOOK_ENABLED gates posting on
# (set to "true" to enable). SMM_REVIEW_DIGEST_MODE flips between real-
# time per-handoff pings ("off" / unset) and the once-a-day rollup cron
# at /api/cron/smm-review-digest ("on").
# SLACK_OPS_WEBHOOK_URL=
# SLACK_OPS_WEBHOOK_ENABLED=false
# SMM_REVIEW_DIGEST_MODE=off
